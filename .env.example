# =============================================================================
# .env.example — PO Galang Dana
# Salin file ini menjadi .env.local dan isi semua nilai yang diperlukan.
# Jangan pernah commit .env.local ke git — sudah dikecualikan di .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — dapatkan dari: Supabase Dashboard → Settings → API
# -----------------------------------------------------------------------------

# URL project Supabase kamu (format: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key — aman untuk digunakan di browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — RAHASIA, HANYA untuk server-side admin operations.
# Kunci ini melewati Row Level Security. Jangan pernah expose ke client.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Database connection strings — dapatkan dari: Supabase Dashboard → Settings → Database
# -----------------------------------------------------------------------------

# Transaction pooler (port 6543) — digunakan oleh aplikasi di runtime.
# Gunakan mode "Transaction" di Supabase connection pooler settings.
# Format: postgresql://postgres.xxxx:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Session pooler atau direct connection (port 5432) — HANYA untuk menjalankan migrations.
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL_DIRECT=

# -----------------------------------------------------------------------------
# Aplikasi
# -----------------------------------------------------------------------------

# URL publik aplikasi ini — digunakan untuk validasi CORS
# Contoh: https://po-lektor.vercel.app (production) atau http://localhost:3000 (development)
NEXT_PUBLIC_APP_URL=http://localhost:3000
